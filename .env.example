# ═══════════════════════════════════════════════════════════════
# JO-Administrativo ERP/POS - Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── Authentication (NextAuth) ───────────────────────────────
# Secret for JWT token signing (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── Pusher (Real-time Notifications) ───────────────────────
NEXT_PUBLIC_PUSHER_APP_ID="your-app-id"
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# ── Optional: Vercel Blob Storage ──────────────────────────
BLOB_READ_WRITE_TOKEN="your-blob-token"

# ── Optional: Resend (Email) ───────────────────────────────
RESEND_API_KEY="re_your-api-key"
